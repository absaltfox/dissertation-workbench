app = "dissertation-workbench"
primary_region = "sjc"

[build]
  dockerfile = "Dockerfile"

[env]
  NODE_ENV = "production"
  PORT = "3000"
  APP_DATA_DIR = "/data"
  SQLITE_PATH = "/data/metrics.sqlite"
  PDF_CACHE_DIR = "/data/pdf-cache"
  FULL_TEXT_CACHE_DIR = "/data/full-text-cache"
  TRUST_PROXY = "1"
  SESSION_COOKIE_SECURE = "1"
  DOWNLOAD_FILES = "0"
  DOCUMENT_SYNC_ENABLED = "0"
  DOCUMENT_SYNC_ON_START = "0"
  DOCUMENT_SYNC_INTERVAL_MS = "86400000"
  DOCUMENT_SYNC_PAGE_SIZE = "100"
  DOCUMENT_SYNC_SCAN_LIMIT = "50000"
  CATALOGUE_LOOKUP_ENABLED = "1"
  CATALOGUE_LOOKUP_ON_START = "1"
  CATALOGUE_LOOKUP_PAGE_SIZE = "200"
  ADMIN_WORKER_MODE = "auto"
  ADMIN_WORKER_TIMEOUT_MS = "21600000"
  ADMIN_WORKER_GRACE_MS = "30000"
  FLY_WORKER_MEMORY_MB = "2048"
  FLY_WORKER_CPUS = "1"
  FLY_WORKER_CPU_KIND = "shared"
  PUBLIC_MAX_RECORDS = "2000"

[[mounts]]
  source = "dissertation_wb_data"
  destination = "/data"

[http_service]
  internal_port = 3000
  force_https = true
  auto_stop_machines = "stop"
  auto_start_machines = true
  min_machines_running = 1

  [http_service.concurrency]
    type = "requests"
    soft_limit = 50
    hard_limit = 100

[[vm]]
  memory = "1gb"
  cpu_kind = "shared"
  cpus = 1
