NODE_ENV=development
PORT=3000

# Upstream Open Collections
UBC_API_BASE_URL=https://oc-index.library.ubc.ca
UBC_INDEX=24
UBC_QUERY=
UBC_TERM=degree.raw,Doctor of Education - EdD
UBC_SOURCE=title,author,ubc_date_sort,uri,creator,supervisor,description,genre,date_available,rights,doi,affiliation,degree_theses,program_theses,scholarly_level,campus,degree,program,extent,identifier,id,subject
UBC_API_KEY=

# Optional local secret encryption. If omitted in development, secrets stored
# through the admin UI remain readable in the local SQLite database.
API_KEY_ENCRYPTION_KEY=
MFA_SECRET_ENCRYPTION_KEY=

# Local storage
APP_DATA_DIR=./data
PDF_CACHE_DIR=./data/pdf-cache
FULL_TEXT_CACHE_DIR=./data/full-text-cache
SQLITE_PATH=./data/metrics.sqlite

# Optional: use a different local env file without changing shell exports.
# ENV_FILE=.env.local

# Runtime defaults
CACHE_TTL_MS=600000
DOWNLOAD_FILES=1
FILE_CONCURRENCY=2

# Reverse proxy / TLS
TRUST_PROXY=0
SESSION_COOKIE_SECURE=0

# Login protection (kept on, but tunable)
LOGIN_WINDOW_MS=900000
LOGIN_BLOCK_MS=900000
LOGIN_MAX_ATTEMPTS_IP=50
LOGIN_MAX_ATTEMPTS_USER=20
LOGIN_FAILURE_DELAY_MS=150

# Public endpoint behavior (dev-friendly)
PUBLIC_MAX_RECORDS=2000
PUBLIC_SCAN_LIMIT=50000
ALLOW_PUBLIC_DOWNLOADS=1
ALLOW_PUBLIC_REFRESH=1
ALLOW_PUBLIC_RECOMPUTE=1

# Error detail exposure
EXPOSE_ERROR_DETAILS=1
