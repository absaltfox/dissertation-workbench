NODE_ENV=production
PORT=3000

# Upstream Open Collections
UBC_API_BASE_URL=https://oc-index.library.ubc.ca
UBC_INDEX=24
UBC_QUERY=
UBC_TERM=degree.raw,Doctor of Education - EdD
UBC_SOURCE=title,author,ubc_date_sort,uri,creator,supervisor,description,genre,date_available,rights,doi,affiliation,degree_theses,program_theses,scholarly_level,campus,degree,program,extent,identifier,id,subject
UBC_API_KEY=REPLACE_WITH_REAL_KEY

# Required production secrets. Use deployment secrets/env, not committed files.
ADMIN_BOOTSTRAP_PASSWORD=REPLACE_WITH_LONG_RANDOM_PASSWORD
API_KEY_ENCRYPTION_KEY=REPLACE_WITH_LONG_RANDOM_VALUE
MFA_SECRET_ENCRYPTION_KEY=REPLACE_WITH_DIFFERENT_LONG_RANDOM_VALUE

# Turso/libSQL production database
TURSO_DATABASE_URL=REPLACE_WITH_TURSO_URL
TURSO_AUTH_TOKEN=REPLACE_WITH_TURSO_TOKEN

# Storage paths (adjust for your host)
APP_DATA_DIR=/var/lib/oc-papers/data
PDF_CACHE_DIR=/var/lib/oc-papers/data/pdf-cache
SQLITE_PATH=/var/lib/oc-papers/data/metrics.sqlite

# Runtime defaults
CACHE_TTL_MS=600000
DOWNLOAD_FILES=1
FILE_CONCURRENCY=2
PDF_ALLOWED_HOSTS=open.library.ubc.ca,oc-index.library.ubc.ca
PDF_ALLOW_HTTP_DOWNLOADS=0

# Admin jobs
BERTOPIC_PYTHON_COMMAND=python3
BERTOPIC_TIMEOUT_MS=3600000

# Reverse proxy / TLS
TRUST_PROXY=1
SESSION_COOKIE_SECURE=1

# Login protection
LOGIN_WINDOW_MS=900000
LOGIN_BLOCK_MS=900000
LOGIN_MAX_ATTEMPTS_IP=25
LOGIN_MAX_ATTEMPTS_USER=10
LOGIN_FAILURE_DELAY_MS=350

# Public endpoint guardrails
PUBLIC_MAX_RECORDS=300
PUBLIC_SCAN_LIMIT=5000
ALLOW_PUBLIC_DOWNLOADS=0
ALLOW_PUBLIC_REFRESH=0
ALLOW_PUBLIC_RECOMPUTE=0

# Error detail exposure
EXPOSE_ERROR_DETAILS=0
